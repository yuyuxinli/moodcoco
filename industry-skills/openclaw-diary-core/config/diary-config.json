{
  "storage": {
    "type": "local",
    "path": "~/write_me/00inbox/journal",
    "feishu": {
      "enabled": false,
      "folder_token": "",
      "comment": "如果启用飞书同步，请设置 folder_token。OpenClaw 会自动使用环境变量中的 FEISHU_APP_ID 和 FEISHU_APP_SECRET"
    },
    "flomo": {
      "enabled": false,
      "api_key": "",
      "comment": "如果启用 Flomo 同步，请设置 api_key"
    },
    "notion": {
      "enabled": false,
      "database_id": "",
      "comment": "如果启用 Notion 同步，请设置 database_id"
    }
  },
  "personality": {
    "type": "enfp",
    "file": "personalities/enfp.md",
    "comment": "可选值：intj（分析型，话少）或 enfp（温暖型，陪聊）"
  },
  "user_identity": {
    "enabled": true,
    "path": "~/write_me/01studio/me",
    "files": {
      "identity": "identity.md",
      "preferences": "preferences.md",
      "social_accounts": "social-accounts.md"
    },
    "comment": "用户身份目录，由 identity-builder skill 创建和维护"
  },
  "date_format": "YYYY-MM",
  "time_boundary": "06:00",
  "triggers": {
    "explicit": ["记一下", "记录", "写日记", "journal", "write this down"],
    "implicit": ["今天发生了", "刚才", "我在想", "today I", "just now"]
  },
  "tags": ["主动记录", "陪读", "协作"],
  "post_processing": {
    "enabled": true,
    "skills": [
      {
        "name": "note-extractor",
        "enabled": false,
        "trigger": "daily",
        "output": "~/write_me/02notes/",
        "description": "从日记提取笔记"
      },
      {
        "name": "life-coach",
        "enabled": false,
        "trigger": "weekly",
        "description": "生成个人成长报告"
      },
      {
        "name": "social-media-writer",
        "enabled": false,
        "trigger": "manual",
        "output": "~/write_me/03output/social/",
        "description": "生成自媒体内容"
      }
    ],
    "comment": "后处理 skills 配置，用户可以自定义添加"
  }
}
