# OpenRouter 账号密钥（交大同学：找蒋老师拿，或用自己的）
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM 配置（默认 minimax-m2.5）
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=${OPENROUTER_API_KEY}
OPENAI_MODEL=minimax/minimax-m2.5

# Slow Agent 读哪个 skills 目录。留空 = backend/skills/（默认 20 个）。
# SJTU 同学要调他们的 7-skill bundle 时取消下一行注释：
# MOODCOCO_SKILLS_DIR=SJTU_skills/moodcoco-psych-companion-v1/skills

# 火山方舟（豆包）API — 用于决策类任务和中文 slow main 候选
# 在 https://console.volcengine.com/ark 申请 key
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
